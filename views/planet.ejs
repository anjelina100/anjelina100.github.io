<!DOCTYPE html>
<html lang="en">

<head>
    <%-include("partials/head.ejs")%>
</head>

<body>
    <h1 class="bg-info text-white p-3 m-0"> The Solar System </h1>

    <%- include("partials/nav.ejs")%>

    <div class="container-fluid row">
        <h2> <%=planet %> </h2>
        <div class="card p-4 col">
            <h2> <%=planet %> </h2>

            <%= planetInfo.description %>
        </div>
        <div class="col card">
            <img src="<%=planetInfo.image %>">
        </div>
        <div class="card p-4 col">

            <h2> The distance from the sun is: </h2><%= planetInfo.distanceFromSun %>
        </div>
        <div class="card p-4 col">

            <h2> The Year Length is: </h2><%= planetInfo.yearLength %>
        </div>
        <div class="card p-4 col">

            <h2> The Radius is: </h2><%= planetInfo.radius %>
        </div>
        <div class="card p-4 col">

            <h2> The website link is: </h2><%= planetInfo.websiteLink %>
        </div>
        <div class="card p-4 col">

            <h2> One Earth day is equal to: </h2><%= planetInfo.oneEarthDay %>
        </div>
        <div class="card p-4 col">

            <h2> Amount of moons: </h2><%= planetInfo.moons %>
        </div>
        <div class="card p-4 col">

            <h2> Defintion: </h2><%= planetInfo.def %>
        </div>
    </div>
    <%-include("partials/footer.ejs")%>
</body>

</html>